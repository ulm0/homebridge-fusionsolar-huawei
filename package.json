{
  "name": "homebridge-fusionsolar-huawei",
  "displayName": "Homebridge FusionSolar",
  "type": "module",
  "version": "1.0.7",
  "private": false,
  "description": "FusionSolar homebridge integration",
  "author": "ulm0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ulm0/homebridge-fusionsolar-huawei#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ulm0/homebridge-fusionsolar-huawei.git"
  },
  "bugs": {
    "url": "https://github.com/ulm0/homebridge-fusionsolar-huawei/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "fusionsolar",
    "luna"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^22.10.0 || ^24.1.0",
    "homebridge": "^1.11.0 || ^2.0.0-beta.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run lint && npm run build",
    "watch": "npm run build && npm link && nodemon",
    "publish": "npm publish --provenance --access public",
    "release": "npm version patch && npm run publish"
  },
  "dependencies": {
    "homebridge-lib": "^7.3.2",
    "npm-check-updates": "^19.6.5",
    "puppeteer": "^24.4.0",
    "puppeteer-extra": "^3.3.6",
    "random-useragent": "^0.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/random-useragent": "^0.3.3",
    "eslint": "^10.1.0",
    "homebridge": "^1.11.3",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1"
  }
}

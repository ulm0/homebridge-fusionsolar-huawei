{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "rootDir": "src/homebridge-ui",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "declaration": false,
    "outDir": "dist/homebridge-ui",
    "sourceMap": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/homebridge-ui/**/*.ts"]
}
